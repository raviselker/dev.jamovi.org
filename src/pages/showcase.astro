---
import BaseLayout from '../layouts/BaseLayout.astro';
import { showcaseModules } from '../data/showcase';
---

<BaseLayout title="Module Showcase | dev.jamovi.org" section="resources">
  <div class="showcase-header">
    <h1>Module <span class="gradient-text">Showcase</span></h1>
    <p class="showcase-subtitle">
      Explore the core modules that power the jamovi analytical experience. 
      Learn from their open-source implementations to build your own.
    </p>
  </div>

  <div class="showcase-grid">
    {showcaseModules.map(module => (
      <div class="showcase-card">
        <div class="showcase-card-header">
          <h3>{module.title}</h3>
        </div>
        <div class="showcase-card-body">
          <p>{module.description}</p>
          <div class="tags">
            {module.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
        <div class="showcase-card-footer">
          <a href={module.github} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm showcase-btn">View on GitHub</a>
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .showcase-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 5rem;
    padding-top: 3rem;
  }

  .showcase-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-top: 1.5rem;
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
    margin: 0 auto 6rem;
    max-width: 1000px; /* Allow more room for 2 columns */
  }

  .showcase-card {
    background-color: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }

  .showcase-card:hover {
    transform: translateY(-8px);
    border-color: var(--primary-color);
    box-shadow: 0 20px 40px -10px rgba(62, 109, 169, 0.15);
  }

  .showcase-card-header {
    padding: 1.75rem 1.75rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
  }

  .showcase-card-header h3 {
    margin: 0;
    font-size: 1.5rem;
    color: var(--text-color);
    letter-spacing: -0.01em;
  }

  .showcase-card-body {
    padding: 2rem 1.75rem;
    flex-grow: 1;
  }

  .showcase-card-body p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .tag {
    font-size: 0.75rem;
    background-color: var(--bg-color-alt);
    color: var(--primary-color);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-weight: 500;
    border: 1px solid var(--border-color);
  }

  .showcase-card-footer {
    padding: 1.75rem;
    background-color: transparent;
    display: flex;
    justify-content: center;
  }

  .showcase-btn {
    width: 100%;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  @media (max-width: 950px) {
    .showcase-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      gap: 2rem;
    }
  }
</style>
